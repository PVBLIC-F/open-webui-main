# AI MODELS
OLLAMA_BASE_URL='http://localhost:11434'

# OpenRouter for GPT-4 summarization via OpenAI-compatible API
OPENAI_API_BASE_URL='https://openrouter.ai/api/v1'
OPENAI_API_KEY='sk-or-v1-xxx'

# Pinecone Settings Chat Summary
PINECONE_API_KEY='pcsk_xxx'
PINECONE_ENVIRONMENT='us-east1-aws'
PINECONE_INDEX_NAME='openweb-ui'
PINECONE_NAMESPACE='chat-summary'
VECTOR_DIM=1024

# Summarization Logic
OPENROUTER_API_KEY='sk-or-v1-xxx'
OPENROUTER_MODEL='openai/gpt-4'
TURNS_BEFORE_SUMMARY=4

# Retrieval Logic
TOP_K=2
KEEP_RECENT_TURNS=3

# Privacy + Analytics
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false
