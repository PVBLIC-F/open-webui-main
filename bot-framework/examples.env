# Example configurations for different AI providers

# ===== OPENWEBUI (Default) =====
# Uses your existing Open WebUI instance
WEBUI_URL=http://localhost:8080
TOKEN=sk-555863f51f064684a5f91586985c715b
AI_PROVIDER=openwebui
AI_MODEL=llama3.2:latest

# ===== OPENAI =====
# Uncomment and configure for OpenAI
# WEBUI_URL=http://localhost:8080
# TOKEN=sk-555863f51f064684a5f91586985c715b
# AI_PROVIDER=openai
# AI_MODEL=gpt-4
# AI_API_KEY=sk-your-openai-key-here

# ===== ANTHROPIC (Claude) =====
# Uncomment and configure for Anthropic
# WEBUI_URL=http://localhost:8080
# TOKEN=sk-555863f51f064684a5f91586985c715b
# AI_PROVIDER=anthropic
# AI_MODEL=claude-3-sonnet-20240229
# AI_API_KEY=sk-ant-your-anthropic-key-here

# ===== OLLAMA =====
# Uncomment and configure for local Ollama
# WEBUI_URL=http://localhost:8080
# TOKEN=sk-555863f51f064684a5f91586985c715b
# AI_PROVIDER=ollama
# AI_MODEL=llama3.2:latest
# AI_BASE_URL=http://localhost:11434

# ===== BOT CONFIGURATION =====
BOT_NAME=AI Assistant
BOT_SYSTEM_PROMPT=You are a helpful AI assistant in a chat channel. Keep responses concise and friendly.
BOT_POLL_INTERVAL=2
BOT_MESSAGE_LIMIT=5
BOT_MAX_MESSAGE_AGE=120
BOT_TRIGGERS=
BOT_DEBUG=false
